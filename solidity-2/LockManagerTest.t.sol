pragma solidity 0.8.22;

import {Test} from "forge-std/Test.sol";
import {DeployProject} from "script/DeployProject.s.sol";
import {LiquidityMigrator, IWETH9} from "src/LiquidityMigrator.sol";
import {BondingCurve} from "src/BondingCurve.sol";
import {BurnableToken} from "src/BurnableToken.sol";
import {FeeAccount} from "src/FeeAccount.sol";
import {BondingCurvesStorage} from "src/BondingCurvesStorage.sol";
import {FactoryManager} from "src/FactoryManager.sol";
import {ISwapRouter} from "@velodrome-finance/slipstream/periphery/interfaces/ISwapRouter.sol";
import {LockManager, ILockManager} from "src/LockManager.sol";
import {ILockPositionsNFT} from "src/interfaces/ILockPositionsNFT.sol";
import {IERC721Errors} from "@openzeppelin/contracts/interfaces/draft-IERC6093.sol";
import {IERC20Errors} from "@openzeppelin/contracts/token/ERC20/ERC20.sol";
import {Ownable} from "@openzeppelin/contracts/access/Ownable.sol";

contract LockManagerTest is Test {
    uint256 constant MINIMAL_DIFF = 1 ether;
    uint256 constant BIG_DIFF = 100 ether;
    uint256 constant MIN_DURATION = 1;
    uint256 constant MAX_DURATION = 365;
    uint256 constant MAX_DURATION_IN_DAYS = 365 days;
    string constant URI1 =
        "data:application/json;base64,";

    string constant URI2 =
        "data:application/json;base64,";

    string constant URI3 =
        "data:application/json;base64,";

    LiquidityMigrator liquidityMigrator;
    BondingCurvesStorage bondingCurvesStorage;
    FactoryManager factoryManager;
    FeeAccount feeAccount;
    BurnableToken burnableToken;
    IWETH9 weth;
    ISwapRouter swapRouter;
    uint256 VESTING_DURATION_USER1 = 12_050_233; // update if USER1 share or duration calculation is changed
    address USER1 = address(1);
    address USER2 = address(2);
    address DEV = address(3);
    string constant ID = "1";
    bytes metadata =
        abi.encode(
            "Test Token",
            "https://example.com/image.png",
            "https://t.me/example"
            "https://twitter.com/example",
            "https://farcast.xyz/example",
            "https://example.com"
        );

    function setUp() external {
        DeployProject deployer = new DeployProject();
        liquidityMigrator = LiquidityMigrator(deployer.run());
        bondingCurvesStorage = BondingCurvesStorage(
            liquidityMigrator.getBondingCurveStorage()
        );
        vm.deal(USER1, 10000 ether);
        vm.deal(USER2, 10000 ether);
        vm.deal(DEV, 10000 ether);
        factoryManager = bondingCurvesStorage.factoryManager();
        feeAccount = FeeAccount(payable(liquidityMigrator.getFeeAccount()));
        swapRouter = ISwapRouter(feeAccount.swapRouter());
        weth = liquidityMigrator.getWeth();
        vm.prank(DEV, DEV);
        vm.warp(0);
        BondingCurve bondingCurve = BondingCurve(
            payable(
                factoryManager.createBondingCurve(
                    "Test",
                    "TEST",
                    metadata,
                    false,
                    ID
                )
            )
        );
        vm.warp(6 seconds);
        vm.roll(block.number + 3);
        burnableToken = BurnableToken(payable(address(bondingCurve.token())));
        vm.prank(USER1, USER1);
        bondingCurve.buyToken{value: MINIMAL_DIFF}(0, ID);
        vm.prank(USER2, USER2);
        bondingCurve.buyToken{value: MINIMAL_DIFF}(0, ID);
        vm.prank(DEV, DEV);
        bondingCurve.buyToken{value: DEV.balance}(0, ID);
    }

    function testUserCanLockToken()
        public
        returns (
            uint256 lockId,
            ILockManager lockManager,
            ILockPositionsNFT positionsNFT
        )
    {
        uint256 initialAmount = burnableToken.balanceOf(USER1);

        vm.startPrank(USER2, USER2);
        burnableToken.approve(address(burnableToken), 1);
        burnableToken.lock(1, MAX_DURATION);
        vm.stopPrank();
        vm.startPrank(USER1, USER1);
        burnableToken.approve(address(burnableToken), initialAmount);
        lockId = burnableToken.lock(initialAmount, MAX_DURATION);
        vm.stopPrank();

        lockManager = burnableToken.lockManager();
        positionsNFT = lockManager.positionsNFT();
        assertTrue(address(lockManager) != address(0));
        assertEq(address(lockManager.dividendToken()), address(burnableToken));
        assertEq(positionsNFT.ownerOf(lockId), USER1);
        uint256[] memory ids = new uint256[](1);
        ids[0] = lockId;
        (
            uint256 lockedAmount,
            uint256 lockShares,
            uint256 unlockTime,

        ) = positionsNFT.positions(lockId);
        assertEq(lockedAmount, initialAmount);
        assertGt(lockShares, initialAmount);
        assertEq(unlockTime, block.timestamp + MAX_DURATION_IN_DAYS);
        assertEq(positionsNFT.getOwnedTokenIds(USER1, 0, 1), ids);

        return (lockId, lockManager, positionsNFT);
    }

    function testUserCantLockTokenLockDurationUnderMinForUnvestedAmount()
        external
    {
        uint256 unvestedAmount = burnableToken.balanceOf(USER1);
        _buyToken(unvestedAmount, USER1);
        vm.startPrank(USER1, USER1);
        burnableToken.approve(
            address(burnableToken),
            burnableToken.balanceOf(USER1)
        );

        vm.expectRevert(
            abi.encodeWithSelector(
                ILockManager
                    .LockManager__LockDurationUnderMinForUnvestedAmount
                    .selector,
                unvestedAmount,
                VESTING_DURATION_USER1
            )
        );
        burnableToken.lock(unvestedAmount, 1);
        vm.stopPrank();
    }

    function testFirstLockIsBoosted() external {
        uint256 initialAmount = burnableToken.balanceOf(USER2);
        uint256 remainingBalance1 = USER1.balance;
        uint256 remainingBalance2 = USER2.balance;

        vm.startPrank(USER2, USER2);
        burnableToken.approve(address(burnableToken), initialAmount);
        uint256 lockId2 = burnableToken.lock(initialAmount, MAX_DURATION);
        vm.stopPrank();
        vm.startPrank(USER1, USER1);
        burnableToken.approve(address(burnableToken), initialAmount);
        uint256 lockId1 = burnableToken.lock(initialAmount, MAX_DURATION);
        burnableToken.burn(burnableToken.balanceOf(USER1));
        vm.stopPrank();

        _buyToken(BIG_DIFF, address(this));
        _sellToken(burnableToken.balanceOf(address(this)), address(this));
        ILockManager lockManager = burnableToken.lockManager();
        feeAccount.collectFeesAndDistribute(payable(address(burnableToken)));
        vm.startPrank(DEV, DEV);
        burnableToken.burn(burnableToken.balanceOf(DEV));
        vm.stopPrank();
        vm.warp(block.timestamp + MAX_DURATION_IN_DAYS + 1);
        vm.roll(block.number + 1);
        vm.prank(USER2);
        lockManager.claimRewards(lockId2);
        vm.prank(USER1);
        lockManager.claimRewards(lockId1);

        assertGt(
            burnableToken.balanceOf(USER2),
            burnableToken.balanceOf(USER1)
        );
        assertGt(
            (address(USER2).balance - remainingBalance2),
            (address(USER1).balance - remainingBalance1)
        );
    }

    function testUserCanClaimRewards() external {
        (
            uint256 lockId,
            ILockManager lockManager,
            ILockPositionsNFT positionsNFT
        ) = testUserCanLockToken();
        (uint256 lockedAmount, , uint256 unlockTime, ) = positionsNFT.positions(
            lockId
        );
        uint256 initialBalance = USER1.balance;

        _buyToken(BIG_DIFF, address(this));
        _sellToken(burnableToken.balanceOf(address(this)), address(this));
        feeAccount.collectFeesAndDistribute(payable(address(burnableToken)));
        vm.warp(unlockTime + 1);
        vm.roll(block.number + 1);
        vm.prank(USER1);
        lockManager.claimRewards(lockId);

        assertGt(burnableToken.balanceOf(USER1), lockedAmount);
        assertGt(USER1.balance, initialBalance);
        assertEq(positionsNFT.getOwnedTokenIds(USER1, 0, 1).length, 0);
        vm.expectRevert(
            abi.encodeWithSelector(
                IERC721Errors.ERC721NonexistentToken.selector,
                lockId
            )
        );
        positionsNFT.ownerOf(lockId);
    }

    function testUserCantClaimRewardsWhenPositionIsLocked() external {
        (uint256 lockId, ILockManager lockManager, ) = testUserCanLockToken();

        vm.prank(USER1);
        vm.expectRevert(
            ILockManager.LockManager__PoisitionNotUnlocked.selector
        );
        lockManager.claimRewards(lockId);
    }

    function testUserCantClaimRewardsWhenNotOwner() external {
        (
            uint256 lockId,
            ILockManager lockManager,
            ILockPositionsNFT positionsNFT
        ) = testUserCanLockToken();
        (, , uint256 unlockTime, ) = positionsNFT.positions(lockId);

        vm.warp(unlockTime + 1);
        vm.roll(block.number + 1);

        vm.expectRevert(
            abi.encodeWithSelector(
                ILockManager.LockManager__NotOwner.selector,
                lockId
            )
        );
        lockManager.claimRewards(lockId);
    }

    function testUsersClaimProportionalRewards() external {
        (
            uint256 lockId1,
            ILockManager lockManager,
            ILockPositionsNFT positionsNFT
        ) = testUserCanLockToken();
        (uint256 lockedAmount1, , uint256 unlockTime, ) = positionsNFT
            .positions(lockId1);
        uint256 initialBalance1 = USER1.balance;
        uint256 initialBalance2 = USER2.balance;

        vm.startPrank(USER2, USER2);
        uint256 lockedAmount2 = burnableToken.balanceOf(USER2);
        burnableToken.approve(address(lockManager), lockedAmount2);
        uint256 lockId2 = lockManager.lock(lockedAmount2, MAX_DURATION);
        vm.stopPrank();

        _buyToken(BIG_DIFF, address(this));
        _sellToken(burnableToken.balanceOf(address(this)), address(this));
        feeAccount.collectFeesAndDistribute(payable(address(burnableToken)));
        vm.warp(unlockTime + 1);
        vm.roll(block.number + 1);
        vm.prank(USER1);
        lockManager.claimRewards(lockId1);
        vm.prank(USER2);
        lockManager.claimRewards(lockId2);

        assertGt(burnableToken.balanceOf(USER1), lockedAmount1);
        assertGt(burnableToken.balanceOf(USER2), lockedAmount2);
        assertGt(
            burnableToken.balanceOf(USER1) - lockedAmount1,
            burnableToken.balanceOf(USER2) - lockedAmount2
        );
        assertGt(USER1.balance, initialBalance1);
        assertGt(USER2.balance, initialBalance2);
        assertGt(
            USER1.balance - initialBalance1,
            USER2.balance - initialBalance2
        );
    }

    function testUsersClaimEquelRewards() external {
        (
            uint256 lockId1,
            ILockManager lockManager,
            ILockPositionsNFT positionsNFT
        ) = testUserCanLockToken();
        (uint256 lockedAmount, , uint256 unlockTime, ) = positionsNFT.positions(
            lockId1
        );
        uint256 remainingBalance1 = USER1.balance;
        uint256 amount = burnableToken.balanceOf(USER2);

        vm.prank(USER2);
        vm.warp(block.timestamp + 365 days);
        vm.roll(block.number + 1);
        burnableToken.transfer(DEV, amount);
        vm.startPrank(DEV, DEV);
        burnableToken.approve(address(lockManager), lockedAmount);
        uint256 lockId2 = lockManager.lock(lockedAmount, MAX_DURATION);
        burnableToken.burn(burnableToken.balanceOf(DEV));
        vm.stopPrank();
        uint256 remainingBalance2 = DEV.balance;

        _buyToken(BIG_DIFF, address(this));
        _sellToken(burnableToken.balanceOf(address(this)) / 2, address(this));
        vm.prank(DEV);
        lockManager.collectRewards(lockId2);
        _sellToken(burnableToken.balanceOf(address(this)), address(this));
        feeAccount.collectFeesAndDistribute(payable(address(burnableToken)));
        vm.stopPrank();
        vm.warp(block.timestamp + unlockTime + 1);
        vm.roll(block.number + 1);
        vm.prank(USER1);
        lockManager.claimRewards(lockId1);
        vm.prank(DEV);
        lockManager.claimRewards(lockId2);

        assertLe(
            burnableToken.balanceOf(DEV) - burnableToken.balanceOf(USER1),
            1
        );
        assertLe(
            (address(DEV).balance - remainingBalance2) -
                (address(USER1).balance - remainingBalance1),
            1
        );
    }

    function testRedistributeDevRewards() external {
        uint256 lockAmount = burnableToken.balanceOf(USER1);
        vm.startPrank(USER1, USER1);
        burnableToken.approve(address(burnableToken), lockAmount);
        uint256 lockId = burnableToken.lock(lockAmount, MAX_DURATION);
        vm.stopPrank();
        ILockManager lockManager = burnableToken.lockManager();
        ILockPositionsNFT positionsNFT = lockManager.positionsNFT();
        (uint256 lockedAmount, , uint256 unlockTime, ) = positionsNFT.positions(
            lockId
        );
        uint256 startAmount = burnableToken.balanceOf(address(lockManager));
        vm.prank(DEV);
        burnableToken.setDev(address(this));

        _buyToken(BIG_DIFF, address(this));
        _sellToken(burnableToken.balanceOf(address(this)), address(this));
        feeAccount.collectFeesAndDistribute(payable(address(burnableToken)));

        assertEq(positionsNFT.balanceOf(DEV), 0);
        assertLe(
            (burnableToken.balanceOf(address(lockManager)) - startAmount) -
                lockManager.collectableRewardOf(lockId),
            1
        );
    }

    function testRedistributeRewardsRevertsIfNotFeeAccount() external {
        (, ILockManager lockManager, ) = testUserCanLockToken();

        vm.expectRevert(ILockManager.LockManager__NotFeeAccount.selector);
        lockManager.redistributeRewards(BIG_DIFF);
    }

    function testDistributeRewardsRevertsIfNotPreApproved() external {
        (, ILockManager lockManager, ) = testUserCanLockToken();

        vm.expectRevert(
            abi.encodeWithSelector(
                IERC20Errors.ERC20InsufficientAllowance.selector,
                address(lockManager),
                0,
                BIG_DIFF
            )
        );
        lockManager.distributeRewards(BIG_DIFF);
    }

    function testCantBurnLockPositionNFTIfNotLockManager() external {
        (, , ILockPositionsNFT positionsNFT) = testUserCanLockToken();

        vm.expectRevert(
            abi.encodeWithSelector(
                Ownable.OwnableUnauthorizedAccount.selector,
                address(this)
            )
        );
        positionsNFT.burn(0);
    }

    function testCantLockFromIfNotToken() external {
        (, ILockManager lockManager, ) = testUserCanLockToken();

        vm.expectRevert(ILockManager.LockManager__NotAuthorized.selector);
        lockManager.lockFor(USER1, BIG_DIFF, MAX_DURATION, false);
    }

    function testCanTransferLockPositionNFT() external {
        (
            uint256 lockId,
            ,
            ILockPositionsNFT positionsNFT
        ) = testUserCanLockToken();
        vm.prank(USER1);
        positionsNFT.safeTransfer(USER2, lockId);

        assertEq(positionsNFT.ownerOf(lockId), USER2);
    }

    function testLockNFTUri() public {
        uint256 initialAmount1 = burnableToken.balanceOf(USER1);
        uint256 initialAmount2 = burnableToken.balanceOf(DEV);
        uint256 initialAmount3 = burnableToken.balanceOf(USER2);
        vm.warp(VESTING_DURATION_USER1 + 1 days);

        vm.startPrank(USER1, USER1);
        burnableToken.approve(address(burnableToken), initialAmount1);
        uint256 lockId1 = burnableToken.lock(initialAmount1, MAX_DURATION);
        vm.stopPrank();
        vm.startPrank(DEV, DEV);
        burnableToken.approve(address(burnableToken), initialAmount2);
        uint256 lockId2 = burnableToken.lock(initialAmount2, MAX_DURATION / 3);
        vm.stopPrank();
        vm.startPrank(USER2, USER2);
        burnableToken.approve(address(burnableToken), initialAmount3);
        uint256 lockId3 = burnableToken.lock(initialAmount3, MAX_DURATION - 1);
        vm.stopPrank();

        ILockManager lockManager = burnableToken.lockManager();
        ILockPositionsNFT positionsNFT = lockManager.positionsNFT();
        vm.warp(block.timestamp + MAX_DURATION_IN_DAYS - 1 days - 1);

        assertEq(positionsNFT.tokenURI(lockId1), URI1);
        assertEq(positionsNFT.tokenURI(lockId2), URI2);
        assertEq(positionsNFT.tokenURI(lockId3), URI3);
    }

    function testLockIdsAreProperlyTracked() external {
        uint256 maxUint = type(uint256).max;
        uint256 amount = 1;
        vm.startPrank(USER1, USER1);
        burnableToken.approve(address(burnableToken), amount * 3);
        uint256 lockId1 = burnableToken.lock(amount, MAX_DURATION);
        uint256 lockId2 = burnableToken.lock(amount, MAX_DURATION);
        uint256 lockId3 = burnableToken.lock(amount, MAX_DURATION);
        vm.stopPrank();

        ILockManager lockManager = burnableToken.lockManager();
        ILockPositionsNFT positionsNFT = lockManager.positionsNFT();
        assertEq(positionsNFT.getOwnedTokenIds(USER1, 0, maxUint).length, 3);

        vm.prank(USER1);
        positionsNFT.safeTransfer(USER2, lockId1);
        assertEq(positionsNFT.getOwnedTokenIds(USER1, 0, maxUint).length, 2);
        assertEq(positionsNFT.getOwnedTokenIds(USER2, 0, maxUint).length, 1);

        vm.prank(USER2);
        positionsNFT.safeTransfer(DEV, lockId1);
        assertEq(positionsNFT.getOwnedTokenIds(USER1, 0, maxUint).length, 2);
        assertEq(positionsNFT.getOwnedTokenIds(USER2, 0, maxUint).length, 0);
        assertEq(positionsNFT.getOwnedTokenIds(DEV, 0, maxUint).length, 1);

        vm.prank(USER1);
        positionsNFT.safeTransfer(USER2, lockId2);
        assertEq(positionsNFT.getOwnedTokenIds(USER1, 0, maxUint).length, 1);
        assertEq(positionsNFT.getOwnedTokenIds(USER2, 0, maxUint).length, 1);
        assertEq(positionsNFT.getOwnedTokenIds(DEV, 0, maxUint).length, 1);

        vm.prank(USER2);
        positionsNFT.safeTransfer(DEV, lockId2);
        assertEq(positionsNFT.getOwnedTokenIds(USER1, 0, maxUint).length, 1);
        assertEq(positionsNFT.getOwnedTokenIds(USER2, 0, maxUint).length, 0);
        assertEq(positionsNFT.getOwnedTokenIds(DEV, 0, maxUint).length, 2);

        vm.prank(USER1);
        positionsNFT.safeTransfer(USER2, lockId3);
        assertEq(positionsNFT.getOwnedTokenIds(USER1, 0, maxUint).length, 0);
        assertEq(positionsNFT.getOwnedTokenIds(USER2, 0, maxUint).length, 1);
        assertEq(positionsNFT.getOwnedTokenIds(DEV, 0, maxUint).length, 2);

        vm.prank(DEV);
        positionsNFT.safeTransfer(USER1, lockId2);
        assertEq(positionsNFT.getOwnedTokenIds(USER1, 0, maxUint).length, 1);
        assertEq(positionsNFT.getOwnedTokenIds(USER2, 0, maxUint).length, 1);
        assertEq(positionsNFT.getOwnedTokenIds(DEV, 0, maxUint).length, 1);

        assertEq(positionsNFT.getOwnedTokenIds(USER1, 0, 1)[0], lockId2);
        assertEq(positionsNFT.getOwnedTokenIds(USER2, 0, 1)[0], lockId3);
        assertEq(positionsNFT.getOwnedTokenIds(DEV, 0, 1)[0], lockId1);
    }

    function _buyToken(
        uint256 amount,
        address recepient
    ) internal returns (uint256) {
        weth.deposit{value: amount}();
        weth.approve(address(swapRouter), amount);

        ISwapRouter.ExactInputSingleParams memory params = ISwapRouter
            .ExactInputSingleParams({
                tokenIn: address(weth),
                tokenOut: address(burnableToken),
                tickSpacing: feeAccount
                    .getCompetingTokenRefferences(address(burnableToken))
                    .pool
                    .tickSpacing(),
                recipient: recepient,
                deadline: block.timestamp,
                amountIn: amount,
                amountOutMinimum: 0,
                sqrtPriceLimitX96: 0
            });

        return swapRouter.exactInputSingle(params);
    }

    function _sellToken(
        uint256 amount,
        address recepient
    ) internal returns (uint256 amountOut) {
        burnableToken.approve(address(swapRouter), amount);

        ISwapRouter.ExactInputSingleParams memory params = ISwapRouter
            .ExactInputSingleParams({
                tokenIn: address(burnableToken),
                tokenOut: address(weth),
                tickSpacing: feeAccount
                    .getCompetingTokenRefferences(address(burnableToken))
                    .pool
                    .tickSpacing(),
                recipient: recepient,
                deadline: block.timestamp,
                amountIn: amount,
                amountOutMinimum: 0,
                sqrtPriceLimitX96: 0
            });

        amountOut = swapRouter.exactInputSingle(params);
        return amountOut;
    }
}
